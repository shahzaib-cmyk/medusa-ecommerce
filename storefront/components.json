{
  "$schema": "https://ui.shadcn.com/schema.json",
  "style": "radix-vega",
  "rsc": true,
  "tsx": true,
  "tailwind": {
    "config": "tailwind.config.js",
    "css": "src/styles/globals.css",
    "baseColor": "neutral",
    "cssVariables": true,
    "prefix": ""
  },
  "iconLibrary": "lucide",
  "rtl": false,
  "menuColor": "default",
  "menuAccent": "subtle",
  "aliases": {
    "components": "@lib/components",
    "utils": "@lib/lib/utils",
    "ui": "@lib/components/ui",
    "lib": "@lib/lib",
    "hooks": "@lib/hooks"
  },
  "registries": {
    "@magicui": "https://magicui.design/r/{name}"
  }
}
